rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // AI-generated activity images are publicly readable
    match /activity-images/{imageId} {
      allow read;
      allow write: if false;
    }

    // All other paths require authentication
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
